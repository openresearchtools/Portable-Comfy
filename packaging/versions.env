# shellcheck shell=bash
# Reproducible upstream inputs for Portable Comfy. Values may be overridden in
# the environment for development builds; release/CI builds should use these
# defaults unchanged.
: "${PYTHON_VERSION:=3.13.12}"
: "${PYTHON_SHA256:=2a84cd31dd8d8ea8aaff75de66fc1b4b0127dd5799aa50a64ae9a313885b4593}"
: "${PYTHON_URL:=https://www.python.org/ftp/python/${PYTHON_VERSION}/Python-${PYTHON_VERSION}.tar.xz}"

: "${COMFY_VERSION:=0.27.0}"
: "${COMFY_TAG:=v${COMFY_VERSION}}"
: "${COMFY_COMMIT:=bb131be9e83d2f773c90f1d6f1e4b248a498c8c5}"
: "${COMFY_ARCHIVE_SHA256:=6398a345c53260c9d20c802c776c8c1dce4078da5c4912b16cd7a6c7396bbf3b}"
: "${COMFY_ARCHIVE_URL:=https://github.com/Comfy-Org/ComfyUI/archive/${COMFY_COMMIT}.tar.gz}"

: "${FRONTEND_VERSION:=1.45.20}"
: "${FRONTEND_COMMIT:=7bd9f8b0d0b854ccb5a947623468f36a392ea0ff}"
: "${FRONTEND_WHEEL_SHA256:=96c05a609f57726bf0c253faa0d554cee350e1cfab23a39debcf398afec5e9e4}"
: "${FRONTEND_WHEEL_URL:=https://files.pythonhosted.org/packages/96/90/3b317d8acabf8f2ac54f3d02bb2e1ffc76631ff886711e30dd031cfba4b7/comfyui_frontend_package-${FRONTEND_VERSION}-py3-none-any.whl}"
: "${FRONTEND_LICENSE_URL:=https://raw.githubusercontent.com/Comfy-Org/ComfyUI_frontend/${FRONTEND_COMMIT}/LICENSE}"
: "${FRONTEND_LICENSE_SHA256:=3972dc9744f6499f0f9b2dbf76696f2ae7ad8af9b23dde66d6af86c9dfb36986}"
: "${FRONTEND_NOTICES_URL:=https://raw.githubusercontent.com/Comfy-Org/ComfyUI_frontend/${FRONTEND_COMMIT}/THIRD_PARTY_NOTICES.md}"
: "${FRONTEND_NOTICES_SHA256:=99d8402cda1959b3055ffeb30b7f12cde0d44a5d6835e741619399c780bca715}"

: "${TORCH_VERSION:=2.12.0+cu130}"
: "${TORCHVISION_VERSION:=0.27.0+cu130}"
: "${TORCHAUDIO_VERSION:=2.11.0+cu130}"
: "${PYTORCH_INDEX_URL:=https://download.pytorch.org/whl/cu130}"
: "${CUDA_VERSION:=13.0}"
: "${COMFY_MANAGER_VERSION:=4.2.2}"
: "${PYGIT2_VERSION:=1.19.3}"
: "${RUNTIME_LOCK_SHA256:=e1ee4b73f35c60595de1db50e390eece8026e5a29d28282daefb645a1e93eabe}"

: "${TAESD_COMMIT:=23f40209607ee9a965a0141fd1754bc6284449b9}"
: "${TAESD_ARCHIVE_URL:=https://github.com/comfyanonymous/taesd/archive/${TAESD_COMMIT}.tar.gz}"
: "${TAESD_ARCHIVE_SHA256:=722ce9472e7ea9f8168a279c51d53e118374e010080a11d0ae64384400a45549}"

: "${PYINSTALLER_VERSION:=6.21.0}"
: "${PYWEBVIEW_VERSION:=6.2.1}"
: "${PYQT6_VERSION:=6.11.0}"
: "${PYQT6_WEBENGINE_VERSION:=6.11.0}"
: "${QTPY_VERSION:=2.4.3}"
: "${QT_RUNTIME_VERSION:=6.11.1}"
: "${QTWEBENGINE_CHROMIUM_LICENSE_URL:=https://raw.githubusercontent.com/qt/qtwebengine/v${QT_RUNTIME_VERSION}/LICENSE.Chromium}"
: "${QTWEBENGINE_CHROMIUM_LICENSE_SHA256:=f34787ef0342c614b667186a6ec2f5d6b9d650e30142a2788a589a89743e88e9}"
: "${PROXY_TOOLS_LICENSE_COMMIT:=db43f1e35d4f90a65c5a4d56d9e9af88212ec6e6}"
: "${PROXY_TOOLS_LICENSE_URL:=https://raw.githubusercontent.com/jtushman/proxy_tools/${PROXY_TOOLS_LICENSE_COMMIT}/LICENSE.txt}"
: "${PROXY_TOOLS_LICENSE_SHA256:=a428fb8a2e762af3eb0a6edbbb88e9b42ccfee80fd9b423958bcacf9b9abbfe4}"

: "${APPIMAGETOOL_VERSION:=1.9.1}"
: "${APPIMAGETOOL_URL:=https://github.com/AppImage/appimagetool/releases/download/${APPIMAGETOOL_VERSION}/appimagetool-x86_64.AppImage}"
: "${APPIMAGETOOL_SHA256:=ed4ce84f0d9caff66f50bcca6ff6f35aae54ce8135408b3fa33abfc3cb384eb0}"
: "${APPIMAGE_RUNTIME_VERSION:=20251108}"
: "${APPIMAGE_RUNTIME_URL:=https://github.com/AppImage/type2-runtime/releases/download/${APPIMAGE_RUNTIME_VERSION}/runtime-x86_64}"
: "${APPIMAGE_RUNTIME_SHA256:=2fca8b443c92510f1483a883f60061ad09b46b978b2631c807cd873a47ec260d}"
: "${APPIMAGE_RUNTIME_LICENSE_URL:=https://raw.githubusercontent.com/AppImage/type2-runtime/${APPIMAGE_RUNTIME_VERSION}/LICENSE}"
: "${APPIMAGE_RUNTIME_LICENSE_SHA256:=aa154fc9070614bbe7921f89db11efd1dba7a1f3a41685958110e2230f9c0ca1}"

# The ComfyUI release commit timestamp. Deterministic archives use this unless
# CI supplies SOURCE_DATE_EPOCH.
: "${SOURCE_DATE_EPOCH:=1782855362}"

export PYTHON_VERSION PYTHON_SHA256 PYTHON_URL
export COMFY_VERSION COMFY_TAG COMFY_COMMIT COMFY_ARCHIVE_SHA256 COMFY_ARCHIVE_URL
export FRONTEND_VERSION FRONTEND_COMMIT FRONTEND_WHEEL_SHA256 FRONTEND_WHEEL_URL
export FRONTEND_LICENSE_URL FRONTEND_LICENSE_SHA256
export FRONTEND_NOTICES_URL FRONTEND_NOTICES_SHA256
export TORCH_VERSION TORCHVISION_VERSION TORCHAUDIO_VERSION PYTORCH_INDEX_URL CUDA_VERSION
export COMFY_MANAGER_VERSION PYGIT2_VERSION RUNTIME_LOCK_SHA256
export TAESD_COMMIT TAESD_ARCHIVE_URL TAESD_ARCHIVE_SHA256
export PYINSTALLER_VERSION PYWEBVIEW_VERSION PYQT6_VERSION PYQT6_WEBENGINE_VERSION QTPY_VERSION
export QT_RUNTIME_VERSION QTWEBENGINE_CHROMIUM_LICENSE_URL
export QTWEBENGINE_CHROMIUM_LICENSE_SHA256
export PROXY_TOOLS_LICENSE_COMMIT PROXY_TOOLS_LICENSE_URL PROXY_TOOLS_LICENSE_SHA256
export APPIMAGETOOL_VERSION APPIMAGETOOL_URL APPIMAGETOOL_SHA256 SOURCE_DATE_EPOCH
export APPIMAGE_RUNTIME_VERSION APPIMAGE_RUNTIME_URL APPIMAGE_RUNTIME_SHA256
export APPIMAGE_RUNTIME_LICENSE_URL APPIMAGE_RUNTIME_LICENSE_SHA256
